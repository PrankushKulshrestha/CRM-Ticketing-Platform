
{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",

    "allowImportingTsExtensions": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "noEmit": true,

    "jsx": "react-jsx",

    "strict": true,

    "ignoreDeprecations": "6.0",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    }
  },

  "include": [
    "src",
    "src/features/analytics/components/AgentPerformanceTab.tsx",
    "../be/src/types/ticket.types.ts"
  ]
}